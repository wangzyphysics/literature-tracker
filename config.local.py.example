"""
本地配置文件示例（不会被提交到 git）
复制为 config.local.py 并填入你自己的密钥：

  cp config.local.py.example config.local.py
"""

# AI 配置（推荐：兼容 OpenAI 的聚合网关）
AI_CONFIG = {
    "provider": "openrouter",
    "api_key": "sk-or-REPLACE_ME",
    # 可以填写根 base URL，代码会自动补全 /chat/completions
    "base_url": "https://supercodex.space/v1",
    # OpenAI-compatible 模型（provider=openrouter 时生效）
    "model": "gpt-5.4(auto)",
}

# 邮件配置（可选）
EMAIL_CONFIG = {
    "sender_email": "",
    "sender_password": "",
}

# 微信推送配置（可选）
WECHAT_CONFIG = {
    "enabled": False,
    "sendkey": "",
}
